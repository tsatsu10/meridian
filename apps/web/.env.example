# ========================================
# Meridian Web Application Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# ========================================
# API CONFIGURATION
# ========================================

# API server URL (backend). Leave unset in local dev to use the Vite `/api` proxy (see vite.config.ts).
# If set, the browser calls this host directly (still requires the API running, typically on port 3005).
VITE_API_URL=http://localhost:3005

# WebSocket server URL
VITE_WS_URL=ws://localhost:3005

# Teams dashboard: when false (default), online presence uses the REST API only; set true to enable useUnifiedWebSocket for presence (higher cost).
VITE_ENABLE_TEAMS_WEBSOCKET=false

# API request timeout (milliseconds)
VITE_API_TIMEOUT=30000

# ========================================
# APPLICATION SETTINGS
# ========================================

# Application mode (development, production)
VITE_APP_MODE=development

# Demo mode (should match backend setting)
VITE_DEMO_MODE=false

# Application title
VITE_APP_TITLE=Meridian

# Application description
VITE_APP_DESCRIPTION=Modern Project Management Platform

# ========================================
# DEMO USER SETTINGS (Demo Mode Only)
# ========================================

# Demo user ID
VITE_DEMO_USER_ID=demo-user

# Demo username
VITE_DEMO_USERNAME=Demo User

# Demo user email
VITE_DEMO_USER_EMAIL=demo@meridian.com

# Demo persona (sarah, jennifer, david, mike, lisa)
VITE_DEMO_PERSONA=mike

# ========================================
# FEATURE FLAGS
# ========================================

# Enable specific features
VITE_ENABLE_GAMIFICATION=true
VITE_ENABLE_GOALS=true
VITE_ENABLE_TIME_TRACKING=true
VITE_ENABLE_VIDEO_CALLS=true
VITE_ENABLE_AI_FEATURES=false
VITE_ENABLE_DARK_MODE=true

# Enable PWA (Progressive Web App)
VITE_ENABLE_PWA=true

# Enable offline mode
VITE_ENABLE_OFFLINE=true

# Enable service worker
VITE_ENABLE_SERVICE_WORKER=true

# ========================================
# ANALYTICS & MONITORING
# ========================================

# Google Analytics ID
VITE_GA_TRACKING_ID=G-XXXXXXXXXX

# Sentry DSN for error tracking
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Sentry environment
VITE_SENTRY_ENVIRONMENT=development

# Sentry traces sample rate (0.0 to 1.0)
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# Enable performance monitoring
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Enable web vitals tracking
VITE_ENABLE_WEB_VITALS=true

# ========================================
# THIRD-PARTY SERVICES
# ========================================

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Cloudinary for image uploads
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# Pusher for real-time (alternative to WebSocket)
VITE_PUSHER_APP_KEY=your-pusher-app-key
VITE_PUSHER_CLUSTER=us2

# Stripe for payments (future)
VITE_STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key

# ========================================
# FILE UPLOAD SETTINGS
# ========================================

# Maximum file upload size (in bytes, default: 50MB)
VITE_MAX_FILE_SIZE=52428800

# Allowed file types (comma-separated)
VITE_ALLOWED_FILE_TYPES=image/*,application/pdf,text/*,.doc,.docx,.xls,.xlsx,.ppt,.pptx

# Image optimization
VITE_ENABLE_IMAGE_OPTIMIZATION=true
VITE_MAX_IMAGE_WIDTH=1920
VITE_MAX_IMAGE_HEIGHT=1080
VITE_IMAGE_QUALITY=85

# ========================================
# UI/UX SETTINGS
# ========================================

# Default theme (light, dark, system)
VITE_DEFAULT_THEME=light

# Default language
VITE_DEFAULT_LANGUAGE=en

# Timezone
VITE_DEFAULT_TIMEZONE=UTC

# Date format (MMM d, yyyy | dd/MM/yyyy | MM/dd/yyyy)
VITE_DATE_FORMAT=MMM d, yyyy

# Time format (12h | 24h)
VITE_TIME_FORMAT=12h

# Items per page (pagination)
VITE_ITEMS_PER_PAGE=50

# Enable animations
VITE_ENABLE_ANIMATIONS=true

# Enable sound effects
VITE_ENABLE_SOUNDS=false

# ========================================
# WEBSOCKET CONFIGURATION
# ========================================

# WebSocket reconnection attempts
VITE_WS_MAX_RECONNECT_ATTEMPTS=5

# WebSocket reconnection delay (milliseconds)
VITE_WS_RECONNECT_DELAY=3000

# WebSocket heartbeat interval (milliseconds)
VITE_WS_HEARTBEAT_INTERVAL=30000

# ========================================
# CACHING & PERFORMANCE
# ========================================

# React Query stale time (milliseconds)
VITE_QUERY_STALE_TIME=300000

# React Query cache time (milliseconds)
VITE_QUERY_CACHE_TIME=600000

# Enable service worker caching
VITE_ENABLE_SW_CACHE=true

# Cache version (increment to invalidate cache)
VITE_CACHE_VERSION=1

# ========================================
# DEVELOPMENT TOOLS
# ========================================

# Enable React Query devtools
VITE_ENABLE_REACT_QUERY_DEVTOOLS=true

# Enable TanStack Router devtools
VITE_ENABLE_ROUTER_DEVTOOLS=true

# Enable Redux devtools (if using Redux)
VITE_ENABLE_REDUX_DEVTOOLS=true

# Enable debug mode
VITE_DEBUG_MODE=false

# Enable verbose logging
VITE_VERBOSE_LOGGING=false

# Client logger minimum level for @/lib/logger (debug | info | warn | error).
# Use warn or error in production to reduce console noise; debug is typical for local dev.
VITE_LOG_LEVEL=debug

# Mock API calls (for testing without backend)
VITE_MOCK_API=false

# ========================================
# BUILD OPTIMIZATION
# ========================================

# Enable code splitting
VITE_ENABLE_CODE_SPLITTING=true

# Enable compression
VITE_ENABLE_COMPRESSION=true

# Enable source maps in production
VITE_ENABLE_SOURCE_MAPS=false

# Bundle size limit warning (KB)
VITE_BUNDLE_SIZE_WARNING=500

# ========================================
# SECURITY
# ========================================

# Content Security Policy nonce (generated per request)
VITE_CSP_NONCE=

# Enable strict mode
VITE_ENABLE_STRICT_MODE=true

# Session timeout (minutes)
VITE_SESSION_TIMEOUT=60

# ========================================
# EXPERIMENTAL FEATURES (Use with caution)
# ========================================

# Enable React Compiler (experimental)
VITE_ENABLE_REACT_COMPILER=false

# Enable concurrent rendering
VITE_ENABLE_CONCURRENT_MODE=false

# Enable automatic batching
VITE_ENABLE_AUTO_BATCHING=true

# ========================================
# NOTES
# ========================================
# 
# PRODUCTION CHECKLIST:
# - Set VITE_APP_MODE=production
# - Set VITE_DEMO_MODE=false
# - Update VITE_API_URL to production URL
# - Update VITE_WS_URL to production WebSocket URL (wss://)
# - Configure production API keys (Google, Sentry, etc.)
# - Disable devtools (VITE_ENABLE_*_DEVTOOLS=false)
# - Enable compression (VITE_ENABLE_COMPRESSION=true)
# - Set appropriate cache times
# - Configure real analytics (GA, Sentry)
# - Test PWA installation
# - Verify CORS settings match backend
# 
# ENVIRONMENT-SPECIFIC FILES:
# - .env.development - Development settings
# - .env.production - Production settings
# - .env.test - Test environment settings
# - .env.local - Local overrides (not committed)
# 
# VITE NOTES:
# - All environment variables MUST start with VITE_
# - Variables are statically replaced at build time
# - Changes require restart of dev server
# - Access in code via import.meta.env.VITE_*
# 
# For more information, see:
# - https://vitejs.dev/guide/env-and-mode
# - README.md
# - ARCHITECTURE.md
# 
# ========================================
