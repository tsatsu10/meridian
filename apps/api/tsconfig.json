{
  // If drizzle relational where-clauses fail with duplicate SQL types, pin typescript@5.6.x in package.json (TS 5.7+ vs drizzle-orm).
  "extends": "../../packages/typescript-config/base.json",

    "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "sourceMap": true,
    "declaration": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "../../node_modules/@types"]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src-backup-*",
    "src/**/__tests__/**",
    "src/__tests__/**",
    "src/tests/**",
    "src/test-utils/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.integration.test.ts"
  ]
}