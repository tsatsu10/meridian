# SECURITY: Never commit real .env files with secrets.
#
# HTTP server (must match apps/web Vite proxy target and VITE_API_URL when using absolute URLs)
API_PORT=3005
# Optional public origin for server-side callbacks (defaults in code use API_PORT)
# API_BASE_URL=http://localhost:3005

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/meridian
# When the DB already matches Drizzle schema but `npm run db:migrate` cannot replay from migration 0000, run:
#   npm run db:ensure-workspace-unique
# Optional dry run: DRY_RUN=1 npm run db:ensure-workspace-unique
# Optional: force TLS for Postgres (default is SSL off for localhost, on for remote hosts)
# DATABASE_SSL=true
# DATABASE_SSL=false
DATABASE_AUTH_TOKEN=your_auth_token_here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Session & Security
SESSION_SECRET=your_session_secret_here_min_32_chars
JWT_SECRET=your_jwt_secret_here_min_32_chars
DEMO_MODE=false
# SECURITY: Must remain false outside local/test.
ALLOW_DEMO_AUTH_BYPASS=false

# Frontend URL (for redirects)
FRONTEND_URL=http://localhost:5174

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# ===== BILLING PROVIDERS =====

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs (create these in Stripe Dashboard)
STRIPE_PRO_PRICE_ID=price_1234567890abcdef
STRIPE_ENTERPRISE_PRICE_ID=price_0987654321fedcba

# Paystack Configuration
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret_here

# Paystack Plan Codes (create these in Paystack Dashboard)
PAYSTACK_PRO_PLAN_CODE=PLN_your_pro_plan_code
PAYSTACK_ENTERPRISE_PLAN_CODE=PLN_your_enterprise_plan_code

# ===== OTHER SERVICES =====

# AWS S3 (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=meridian-uploads

# Cloudinary (alternative for images)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# OAuth Providers (for integrations)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# WebSocket Configuration
WS_PORT=3005
WS_PATH=/ws

# Monitoring & Logging
LOG_LEVEL=debug
SENTRY_DSN=https://your_sentry_dsn_here

# Geolocation Service (Optional)
# Get your free API key at https://ipstack.com
IPSTACK_API_KEY=your_ipstack_api_key_here
IPSTACK_SECURITY=false  # Set to true for HTTPS (requires paid plan)

# Weather Service (Optional)
# Get your free API key at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here
OPENWEATHERMAP_UNITS=metric  # metric (Celsius) or imperial (Fahrenheit)

# Photo Library Service (Optional)
# Get your free access key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here
UNSPLASH_SECRET_KEY=your_unsplash_secret_key_here  # Optional, for write operations
UNSPLASH_APP_NAME=Meridian  # Your application name

# Feature Flags
ENABLE_ANALYTICS=true
ENABLE_AI_FEATURES=false
ENABLE_BILLING=true
# Set to false to disable /api/geolocation, /api/weather, /api/unsplash (web widgets use weather/unsplash).
ENABLE_GEO_WEATHER_UNSPLASH=true
