{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignore": [
      "**/routeTree.gen.ts",
      "**/node_modules",
      "**/dist",
      "**/.next",
      "**/coverage",
      "**/*.min.js",
      "**/.cursor/**",
      "**/docs/**",
      "**/prototypes/**",
      "**/playwright-report/**",
      "**/test-results/**",
      "apps/web/eslint-plugin-meridian-local/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn"
      },
      "complexity": {
        "noStaticOnlyClass": "warn"
      },
      "a11y": {
        "useSemanticElements": "warn",
        "useKeyWithClickEvents": "warn",
        "noLabelWithoutControl": "warn"
      }
    }
  },
  "organizeImports": {
    "enabled": false
  },
  "overrides": [
    {
      "include": ["**/tsconfig.json", "**/tsconfig.*.json", "**/*.jsonc"],
      "json": {
        "parser": {
          "allowComments": true,
          "allowTrailingCommas": true
        }
      }
    }
  ]
}
