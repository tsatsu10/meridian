{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignore": [
      "**/node_modules",
      "**/dist",
      "**/.next",
      "**/coverage",
      "**/*.min.js",
      "**/.cursor/**",
      "**/docs/**",
      "**/prototypes/**",
      "**/playwright-report/**",
      "**/test-results/**",
      "apps/web/eslint-plugin-meridian-local/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "organizeImports": {
    "enabled": false
  }
}
